# Copy this file to .env and set your values.
#
# MongoDB Atlas – use EITHER (A) or (B):
#
# (A) Password in URL (use only if password has NO special characters like @ # : /):
# MONGODB_URI=mongodb+srv://chamithsamarakon_db_user:YourPassword@cluster0.ppqoeyc.mongodb.net/pearl_path?retryWrites=true&w=majority&appName=Cluster0
#
# (B) Password in separate variable (recommended – works with any password):
MONGODB_URI=mongodb+srv://chamithsamarakon_db_user:<db_password>@cluster0.ppqoeyc.mongodb.net/pearl_path?retryWrites=true&w=majority&appName=Cluster0
MONGODB_PASSWORD=your_actual_atlas_password
